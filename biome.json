{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always",
      "arrowParentheses": "always"
    }
  },
  "files": {
    "includes": ["**/*.mjs", "**/*.ts"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": { "maxAllowedComplexity": 30 }
        }
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "performance": {
        "noDelete": "warn"
      },
      "style": {
        "useConst": "error",
        "useNodejsImportProtocol": "error",
        "noParameterAssign": "error"
      },
      "suspicious": {
        "noAsyncPromiseExecutor": "error",
        "noConsole": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["scripts/**", ".claude/skills/**/*.mjs"],
      "linter": {
        "rules": {
          "suspicious": { "noConsole": "off" }
        }
      }
    },
    {
      "includes": ["**/test/**/*.mjs", "**/*.test.mjs"],
      "linter": {
        "rules": {
          "suspicious": { "noConsole": "off" },
          "complexity": { "noExcessiveCognitiveComplexity": "off" }
        }
      }
    }
  ]
}
