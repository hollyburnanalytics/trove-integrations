# Copy to .env and fill in as needed. .env is git-ignored.
# Most sources need no secrets; these are for the optional API-keyed
# sources and the toolkits under mcp/.

# --- MCP server secrets (only needed for the servers that declare them) ---
OPENALEX_API_KEY=
FRED_API_KEY=
MAPBOX_TOKEN=
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# x (X / Twitter API v2) — read tools need the app-only bearer token; the
# get_bookmarks tool and the x-bookmarks source additionally need OAuth 2.0
# user-context credentials (X_OAUTH_CLIENT_SECRET only for a confidential client).
X_BEARER_TOKEN=
X_OAUTH_CLIENT_ID=
X_OAUTH_CLIENT_SECRET=
X_OAUTH_REFRESH_TOKEN=

# resend (mutating MCP server) — recipient is fixed to this address
RESEND_API_KEY=
RECIPIENT_EMAIL=
