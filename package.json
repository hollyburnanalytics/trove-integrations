{
  "name": "trove-integrations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Hollyburn Analytics Inc.",
  "description": "Data-source connectors and MCP tool servers that connect Trove (and AI agents) to the outside world.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hollyburnanalytics/trove-integrations.git"
  },
  "packageManager": "bun@1.3.2",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "typecheck": "bun run typecheck:mcp && bun run typecheck:sources",
    "typecheck:mcp": "tsc --noEmit -p mcp/tsconfig.json",
    "typecheck:sources": "tsc -p tsconfig.sources.json",
    "connector": "bun bin/run-connector.mjs",
    "check": "bun run lint && bun run lint:sonar && bun run test:coverage && bun run typecheck && bun run validate",
    "validate": "bun scripts/validate-registry.mjs",
    "lint:sonar": "eslint ."
  },
  "dependencies": {
    "node-html-parser": "^8.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@ontrove/mcp": "^0.1",
    "bun-types": "^1.3.14",
    "eslint": "^10.1.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "typescript": "^6.0.2",
    "zod": "^3.25.28"
  }
}
